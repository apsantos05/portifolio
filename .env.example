# ─────────────────────────────────────────────────────────────
#  Variáveis de ambiente — copie para .env.local e preencha.
#  O .env.local é ignorado pelo Git (nunca comitar chaves).
# ─────────────────────────────────────────────────────────────

# Resend — envio real de e-mails (https://resend.com/api-keys)
# Sem esta chave o site funciona normalmente; o envio real liga quando ela existir.
RESEND_API_KEY=

# Para onde os leads de contato chegam (padrão: e-mail do site em lib/site.ts)
CONTACT_TO_EMAIL=

# Remetente. Use 'onboarding@resend.dev' para testes (só envia para o e-mail da conta),
# ou 'Nome <contato@seudominio.com>' com um domínio verificado no Resend.
CONTACT_FROM_EMAIL=

# (Opcional) Audiência do Resend para a newsletter. Se vazio, inscrições viram
# uma notificação por e-mail para CONTACT_TO_EMAIL.
RESEND_AUDIENCE_ID=
