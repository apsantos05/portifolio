# ─────────────────────────────────────────────────────────────
#  Variáveis de ambiente — copie para .env.local e preencha.
#  O .env.local é ignorado pelo Git (nunca comitar chaves).
#  Na Vercel: Project → Settings → Environment Variables.
# ─────────────────────────────────────────────────────────────

# Resend — envio real de e-mails (https://resend.com/api-keys)
# Cole aqui a sua chave (começa com "re_"). Sem ela, o site funciona e apenas
# registra o lead; o WhatsApp continua abrindo normalmente.
RESEND_API_KEY=

# Para onde os leads de contato chegam.
# Trocar por contato@arthurpsantos.tech no futuro é só mudar esta linha.
CONTACT_TO_EMAIL=arthurpsantos05@gmail.com

# Remetente. 'onboarding@resend.dev' funciona sem domínio verificado, porém só
# entrega para o e-mail da SUA conta Resend (por isso CONTACT_TO_EMAIL deve ser esse e-mail).
# Depois, com domínio verificado no Resend: 'Arthur Santos <contato@arthurpsantos.tech>'.
CONTACT_FROM_EMAIL=onboarding@resend.dev

# (Opcional) Audiência do Resend para a newsletter. Se vazio, inscrições viram
# uma notificação por e-mail para CONTACT_TO_EMAIL.
RESEND_AUDIENCE_ID=
